#include <iostream>
using namespace std;

int main()
{
    int numeros[10];
    int *ptr;
    int mayor;

    cout << "Ingrese 10 numeros enteros:" << endl;

    // Ingreso de datos
    for(int i = 0; i < 10; i++)
    {
        cout << "Numero " << i + 1 << ": ";
        cin >> numeros[i];
    }

    // El puntero apunta al inicio del arreglo
    ptr = numeros;

    // Inicializar el mayor con el primer elemento
    mayor = *ptr;

    // Recorrer el arreglo usando punteros
    for(int i = 1; i < 10; i++)
    {
        if(*(ptr + i) > mayor)
        {
            mayor = *(ptr + i);
        }
    }

    cout << "\nNumeros ingresados:" << endl;

    for(int i = 0; i < 10; i++)
    {
        cout << *(ptr + i) << " ";
    }

    cout << "\n\nEl numero mayor es: " << mayor << endl;

    return 0;
}
