#include <iostream>
#include <cstring>
using namespace std;

int main()
{
    char palabra[50];
    char *ptr;
    int contadorVocales = 0;

    cout << "Ingrese una palabra: ";
    cin >> palabra;

    // El puntero apunta al inicio de la cadena
    ptr = palabra;

    // Recorrer la palabra utilizando punteros
    while(*ptr != '\0')
    {
        if(*ptr == 'a' || *ptr == 'e' || *ptr == 'i' || 
           *ptr == 'o' || *ptr == 'u' ||
           *ptr == 'A' || *ptr == 'E' || *ptr == 'I' || 
           *ptr == 'O' || *ptr == 'U')
        {
            contadorVocales++;
        }

        ptr++;
    }

    cout << "\nPalabra ingresada: " << palabra << endl;
    cout << "Cantidad de vocales: " << contadorVocales << endl;

    return 0;
}
