#include <iostream>
using namespace std;

int main()
{
    int cantidad;
    int aux;

    int *ptr;

    cout << "Ingrese la cantidad de elementos del arreglo: ";
    cin >> cantidad;

    // Reservar memoria dinámica
    ptr = new int[cantidad];

    // Ingreso de datos
    cout << "\nIngrese los valores del arreglo:" << endl;

    for(int i = 0; i < cantidad; i++)
    {
        cout << "Elemento " << i + 1 << ": ";
        cin >> *(ptr + i);
    }

    // Ordenamiento usando punteros
    for(int i = 0; i < cantidad; i++)
    {
        for(int j = i + 1; j < cantidad; j++)
        {
            if(*(ptr + i) > *(ptr + j))
            {
                aux = *(ptr + i);
                *(ptr + i) = *(ptr + j);
                *(ptr + j) = aux;
            }
        }
    }

    cout << "\nArreglo ordenado de menor a mayor:" << endl;

    for(int i = 0; i < cantidad; i++)
    {
        cout << *(ptr + i) << " ";
    }

    // Liberar memoria
    delete[] ptr;

    return 0;
}
