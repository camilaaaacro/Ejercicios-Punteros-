#include <iostream>
using namespace std;

int main()
{
    int numeros[10];
    int *ptr;
    int menor;

    cout << "Ingrese 10 numeros enteros:" << endl;

    // Ingreso de datos
    for(int i = 0; i < 10; i++)
    {
        cout << "Numero " << i + 1 << ": ";
        cin >> numeros[i];
    }

    // El puntero apunta al inicio del arreglo
    ptr = numeros;

    // Inicializar menor con el primer elemento
    menor = *ptr;

    // Buscar el menor usando punteros
    for(int i = 1; i < 10; i++)
    {
        if(*(ptr + i) < menor)
        {
            menor = *(ptr + i);
        }
    }

    cout << "\nNumeros ingresados:" << endl;

    for(int i = 0; i < 10; i++)
    {
        cout << *(ptr + i) << " ";
    }

    cout << "\n\nEl numero menor es: " << menor << endl;

    return 0;
}
