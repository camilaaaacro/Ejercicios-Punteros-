#include <iostream>
#include <cstring>
using namespace std;

int main()
{
    char palabra[50];
    char invertida[50];

    char *ptrOriginal;
    char *ptrInvertida;

    int longitud;

    cout << "Ingrese una palabra: ";
    cin >> palabra;

    // Obtener longitud de la palabra
    longitud = strlen(palabra);

    // Asignar punteros
    ptrOriginal = palabra;
    ptrInvertida = invertida;

    // Invertir la palabra usando punteros
    for(int i = longitud - 1; i >= 0; i--)
    {
        *ptrInvertida = *(ptrOriginal + i);
        ptrInvertida++;
    }

    // Agregar final de cadena
    *ptrInvertida = '\0';

    cout << "\nPalabra original: " << palabra << endl;
    cout << "Palabra invertida: " << invertida << endl;

    return 0;
}
