#include <iostream>
using namespace std;

int main()
{
    int cantidad;
    int suma = 0;

    int *ptr;

    cout << "Ingrese la cantidad de elementos del arreglo: ";
    cin >> cantidad;

    // Reservar memoria dinámica utilizando punteros
    ptr = new int[cantidad];

    // Ingreso de valores
    cout << "\nIngrese los valores del arreglo:" << endl;

    for(int i = 0; i < cantidad; i++)
    {
        cout << "Elemento " << i + 1 << ": ";
        cin >> *(ptr + i);
    }

    // Sumar elementos usando punteros
    for(int i = 0; i < cantidad; i++)
    {
        suma = suma + *(ptr + i);
    }

    cout << "\nElementos ingresados:" << endl;

    for(int i = 0; i < cantidad; i++)
    {
        cout << *(ptr + i) << " ";
    }

    cout << "\n\nLa suma total es: " << suma << endl;

    // Liberar memoria reservada
    delete[] ptr;

    return 0;
}
