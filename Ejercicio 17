#include <iostream>
using namespace std;

int main()
{
    int arreglo1[5];
    int arreglo2[5];

    int *ptr1;
    int *ptr2;

    cout << "Ingrese 5 numeros enteros:" << endl;

    // Ingreso de datos al primer arreglo
    for(int i = 0; i < 5; i++)
    {
        cout << "Numero " << i + 1 << ": ";
        cin >> arreglo1[i];
    }

    // Asignar punteros a los arreglos
    ptr1 = arreglo1;
    ptr2 = arreglo2;

    // Copiar usando punteros
    for(int i = 0; i < 5; i++)
    {
        *(ptr2 + i) = *(ptr1 + i);
    }

    cout << "\nContenido del arreglo original:" << endl;

    for(int i = 0; i < 5; i++)
    {
        cout << *(ptr1 + i) << " ";
    }

    cout << "\n\nContenido del arreglo copiado:" << endl;

    for(int i = 0; i < 5; i++)
    {
        cout << *(ptr2 + i) << " ";
    }

    return 0;
}
