#include <iostream>
using namespace std;

int main()
{
    int numeros[5];
    int *ptr;
    int suma = 0;
    float promedio;

    // Ingreso de datos
    cout << "Ingrese 5 numeros enteros:" << endl;

    for(int i = 0; i < 5; i++)
    {
        cout << "Numero " << i + 1 << ": ";
        cin >> numeros[i];
    }

    // El puntero apunta al primer elemento del arreglo
    ptr = numeros;

    // Recorrer arreglo usando punteros
    for(int i = 0; i < 5; i++)
    {
        suma = suma + *(ptr + i);
    }

    promedio = suma / 5.0;

    cout << "\nValores ingresados:" << endl;

    for(int i = 0; i < 5; i++)
    {
        cout << *(ptr + i) << " ";
    }

    cout << "\n\nLa suma es: " << suma << endl;
    cout << "El promedio es: " << promedio << endl;

    return 0;
}
