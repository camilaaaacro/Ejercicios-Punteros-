#include <iostream>
using namespace std;

int main()
{
    int numeros[5];
    int *ptr;
    int aux;

    cout << "Ingrese 5 numeros enteros:" << endl;

    // Ingreso de datos
    for(int i = 0; i < 5; i++)
    {
        cout << "Numero " << i + 1 << ": ";
        cin >> numeros[i];
    }

    // El puntero apunta al primer elemento
    ptr = numeros;

    // Ordenamiento usando punteros
    for(int i = 0; i < 5; i++)
    {
        for(int j = i + 1; j < 5; j++)
        {
            if(*(ptr + i) > *(ptr + j))
            {
                aux = *(ptr + i);
                *(ptr + i) = *(ptr + j);
                *(ptr + j) = aux;
            }
        }
    }

    cout << "\nArreglo ordenado de menor a mayor:" << endl;

    for(int i = 0; i < 5; i++)
    {
        cout << *(ptr + i) << " ";
    }

    return 0;
}
